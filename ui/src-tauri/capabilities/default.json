{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the PropEdge main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:8000/*" },
        { "url": "https://*:8000/*" },
        { "url": "wss://*:8000/*" },
        { "url": "ws://localhost:8000/*" }
      ]
    },
    "shell:allow-open"
  ]
}
